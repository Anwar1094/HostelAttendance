.data-container {
  position: absolute;
  display: flex;
  flex-wrap: wrap;
  gap: 1px;
  max-height: 90%;
  overflow-y: auto;
  padding-right: 15px;
  top: 40px;
  left: 50%;
  width: 95%;
  transform: translateX(-50%);
}

.data-box {
  border: 1px solid #333;
  padding: 15px;
  
  width: 100%;  /* Makes the box take up the available space */
  /* min-width: 10; Prevents the box from getting too wide */
  text-align: left;
  background-color: #f9f9f9;
  box-sizing: border-box;  /* Ensures padding and border are included in the width */
  margin-bottom: 15px;  /* Adds spacing between stacked items */
}

/* Custom Scrollbar */
.data-container::-webkit-scrollbar {
  width: 10px; /* Width of the scrollbar */
  
}

.data-container::-webkit-scrollbar-track {
  background-color: #f1f1f1; /* Track color */
  border-radius: 10px;
  
}

.data-container::-webkit-scrollbar-thumb {
  background-color: #888; /* Scrollbar handle color */
  border-radius: 10px;
  border: 3px solid #f1f1f1; /*Add space between the handle and track*/
}

.data-container::-webkit-scrollbar-thumb:hover {
  background-color: #555; /* Color of the handle when hovered */
}



