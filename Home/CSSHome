/* Responsive Design */

  /* media queri code for laptop or computer screen  */

  @media screen and (max-width: 980px) {


    .navbar {
      display: grid;
      grid-template-columns: 10% 78% 12%;
      justify-items: center;
    }

    .invertis-logo-media {
      display: block;
      width: 200px;
      height: 80px;
      margin: 20px;
      align-items: center;
     
    }

    .invertis-logo-media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  
    .nav-links-a:after {
      position: relative;
    }


    .nav-links-a:hover {
      color: rgba(255, 255, 255, 0.604);
    }
    .nav-links {
      display: none;
      flex-direction: column;
      position: absolute;
      top: 120px;
      left: 0;
      width: 250px;
      background: #444;
      z-index: 10;
      padding: 10px 0;
      justify-content: left;
      text-align: left;
    }


    .nav-links a {
      color: white;
    }
    .invertis-logo {
      display: none;
    }
  
    .hamburger {
      display: flex;
      align-self: center;
    }
  
    .nav-links.active {
      display: flex;
    }
  
    .student-details-div {
      width: 300px;
      height: 75vh;
      margin: 2%;
    }
  
    .content-container {
      /* max-height: 500px; */
      height: 400px;
      overflow-y: auto;
    }
    .grid {
      display: grid;
      grid-template-columns: auto auto;
    }
  
    .field {
      display: flex;
      justify-content: center;
      text-align: center;
      width: 100%;
    }
    .academic-calendar {
      width: 60%;
      height: 75vh;
    }  

}


